# --- Локальная разработка с Supabase Postgres + Docker Redis ---
# Скопируй этот файл в .env (или .env.local), подставь реальные значения
# для Discogs/OpenAI и т.д. Подробности — docs/dev/DEV_SETUP_LOCAL.md

APP_NAME=Вертушка
APP_VERSION=1.0.0-dev
DEBUG=true

# --- БД: локальный Supabase Postgres (порт 54322) ---
# postgres/postgres — дефолтные креды Supabase CLI
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# --- Redis: docker-compose.dev.yml ---
REDIS_URL=redis://localhost:6379/0

# --- Секреты (для dev пойдёт любая строка) ---
SECRET_KEY=local-dev-secret-change-me
JWT_SECRET_KEY=local-dev-jwt-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=90

# --- Discogs API (нужен токен — иначе ценовая стата не работает) ---
DISCOGS_API_KEY=
DISCOGS_API_SECRET=
DISCOGS_TOKEN=
DISCOGS_USER_AGENT=VertushkaDev/1.0

# --- OpenAI Vision (для распознавания обложек — опционально для парсера) ---
OPENAI_API_KEY=

# --- Email (опционально — выключено для dev) ---
RESEND_API_KEY=
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# --- Frontend / app URL ---
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8081

# --- Парсеры магазинов винила ---
# Включает APScheduler-задачи парсинга. На dev держи false и запускай вручную
# через `python -m app.scripts.scrape_all --slug=...`
SCRAPERS_ENABLED=false
# IS_SCHEDULER управляет всем cron'ом (бронирования, цены, ачивки, парсеры).
# На dev лучше держать false, чтобы не молотить фоновые задачи.
IS_SCHEDULER=false

# Прокси для парсеров (формат: "http://host:port,http://host:port,...")
# Пусто = ходим напрямую. Для РФ-магазинов с РФ-IP обычно не нужно.
SCRAPER_PROXIES=

# --- Storage обложек (локально сохраняем в uploads/covers) ---
COVERS_DIR=uploads/covers
COVERS_MAX_CACHE_MB=2000

# --- Sentry (выкл для dev) ---
SENTRY_DSN=

# --- Прочее ---
INTERNAL_API_TOKEN=local-internal-token
